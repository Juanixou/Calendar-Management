{
  "name": "gestion-de-clases",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:reset": "npm run dev:reset -w apps/web",
