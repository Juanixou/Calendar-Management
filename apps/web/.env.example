# Copy this file to .env.local and fill in your own Firebase project's config
# (Project settings -> General -> Your apps -> SDK setup and configuration).
# These values are safe to expose in client code by Firebase's own design — real
# security comes from Firestore security rules + Firebase Auth, not from hiding these.
# See docs/firebase-setup.md for the full setup guide.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
